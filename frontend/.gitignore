# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Environment variables — NEVER commit these
.env
*.env

# Alembic (keep structure, ignore local db)
*.db
*.sqlite

# Local file uploads
backend/static/uploads/

# Node
node_modules/
dist/
.DS_Store

# IDE
.vscode/
.idea/
EOF
