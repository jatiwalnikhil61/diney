cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Environment variables — NEVER commit these
.env
*.env

# Alembic (keep structure, ignore local db)
*.db
*.sqlite

# Local file uploads
backend/static/uploads/

# Node
node_modules/
dist/
.DS_Store

# IDE
.vscode/
.idea/
EOF