# Neon database — change postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/dbname?ssl=require

# JWT (not used this phase but set it now)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256

# SMSBridge (not used this phase)
SMSBRIDGE_HOST=
SMSBRIDGE_API_KEY=
SMSBRIDGE_DEVICE_ID=

# Storage
STORAGE_BACKEND=local

# Dev mode — prints OTP to terminal instead of sending SMS
DEV_MODE=true

# Seed
SEED_PHONE=+91XXXXXXXXXX

# Frontend URL
FRONTEND_URL=http://localhost:5173
